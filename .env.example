# ─── 텔레그램 ───
# 실제 키: ~/tools/coin/.env 참조
TELEGRAM_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ─── Notion ───
# 실제 키: ~/tools/coin/.env 참조 (grep NOTION ~/tools/coin/.env)
NOTION_API_KEY=               # ~/tools/coin/.env에서 복사
NOTION_PAGE_ID=               # 연동할 페이지 ID (연동 시 물어볼 것)
NOTION_DB_ID=                 # 연동할 데이터베이스 ID (연동 시 물어볼 것)
